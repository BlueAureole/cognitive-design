<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="xyz.zhiwei.cognitivedesign.dao.impl.rpc.transaction.recorder.TransactionRecordDaoImpl" >
  <resultMap id="BaseResultMap" type="xyz.zhiwei.cognitivedesign.dao.impl.rpc.transaction.model.TransactionRecord" >
    <result column="transaction_key" property="transactionKey" jdbcType="VARCHAR" />
    <result column="status" property="status" jdbcType="INTEGER" />
    <result column="principle_name" property="principleName" jdbcType="VARCHAR" />
    <result column="operation" property="operation" jdbcType="VARCHAR" />
    <result column="param" property="param" jdbcType="VARCHAR" />
    <result column="resp" property="resp" jdbcType="VARCHAR" />
  </resultMap>

  <sql id="Base_Column_List" >
    transaction_key, status, principle_name, operation, param,resp
  </sql>
  
  <!-- ==========================================查询=========================================== -->
  <select id="selectByTxKey" resultMap="BaseResultMap" parameterType="xyz.zhiwei.cognitivedesign.dao.impl.rpc.transaction.model.TransactionRecord" >
    select 
    <include refid="Base_Column_List" />
    from transaction_record
    where transaction_key = #{transactionKey,jdbcType=VARCHAR}
  </select>
  
  <select id="selectByExample" resultMap="BaseResultMap" parameterType="xyz.zhiwei.cognitivedesign.dao.impl.rpc.transaction.model.TransactionRecord" >
    select 
    <include refid="Base_Column_List" />
    from transaction_record
    <where>
      <if test="transactionKey != null" >
        and transaction_key = #{transactionKey,jdbcType=VARCHAR}
      </if>
      <if test="status != null" >
        and status = #{status,jdbcType=INTEGER}
      </if>
      <if test="principleName != null" >
        and principle_name = #{principleName,jdbcType=VARCHAR}
      </if>
      <if test="operation != null" >
        and operation = #{operation,jdbcType=VARCHAR}
      </if>
    </where>
  </select>
  
  <!-- ==========================================新增=========================================== -->
  <insert id="insert" parameterType="xyz.zhiwei.cognitivedesign.dao.impl.rpc.transaction.model.TransactionRecord" >
    insert into transaction_record (
      transaction_key, status, principle_name, operation, param, create_time, update_time
    )
    values (
      #{transactionKey,jdbcType=VARCHAR}, #{status,jdbcType=INTEGER}, 
      #{principleName,jdbcType=VARCHAR}, #{operation,jdbcType=VARCHAR}, #{param,jdbcType=VARCHAR}, 
      now(), now()
    )
  </insert>

  <!-- ==========================================编辑=========================================== -->
  <update id="updateByTxKey" parameterType="xyz.zhiwei.cognitivedesign.dao.impl.rpc.transaction.model.TransactionRecord" >
    update transaction_record
    <set >
      <if test="status != null" >
        status = #{status,jdbcType=INTEGER},
      </if>
      <if test="resp != null" >
        resp = #{resp,jdbcType=VARCHAR},
      </if>
      update_time = now()
    </set>
    where transaction_key = #{transactionKey,jdbcType=VARCHAR}
  </update>

  <!-- ==========================================删除=========================================== -->
  
  <delete id="deleteByTxKey" parameterType="xyz.zhiwei.cognitivedesign.dao.impl.rpc.transaction.model.TransactionRecord" >
    delete from transaction_record
    where transaction_key = #{transactionKey,jdbcType=VARCHAR}
  </delete>

</mapper>
